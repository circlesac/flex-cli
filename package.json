    "dev": "bun run src/index.ts"
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "citty": "^0.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/circlesac/flex-cli"
  }
}
