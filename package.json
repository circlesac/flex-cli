{
  "name": "@circlesac/flex",
  "description": "CLI for Flex HR (flex.team)",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "flex": "bin/flex.mjs"
  },
  "files": [
    "bin",
    "skills"
  ],
  "scripts": {
    "postinstall": "node bin/install.js",
